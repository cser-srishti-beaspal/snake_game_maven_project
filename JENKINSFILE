pipeline {
    agent any

    environment {
        IMAGE_NAME = "snake-game"
        CONTAINER_NAME = "snake-container"
    }
    stages {
        stage('Build Maven Project') {
            steps {
                bat 'mvn clean package'
            }
        }
        stage('Build Docker Image') {
            steps {
                powershell 'docker build -t %IMAGE_NAME% .'
            }
        }
        stage('Remove Old Container') {
            steps {
                powershell 'docker rm -f %CONTAINER_NAME% || exit 0'
            }
        }
        stage('Run Container') {
            steps {
                powershell 'docker run -d --name %CONTAINER_NAME% %IMAGE_NAME%'
            }
        }
    }
    post {
        success {
            echo 'Pipeline executed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}